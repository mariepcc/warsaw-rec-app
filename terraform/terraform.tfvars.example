# AWS region
aws_region  = "your-aws-region"

# Application name
app_name    = "your-app-name"
environment = "prod"

# Domain — must be purchased and NS records pointed to Route 53
domain_name = "your-domain.com"

# Database
db_username = "your-db-username"
db_password = "CHANGE_TO_STRONG_PASSWORD"  # min. 16 chars, upper/lower/digits/special

# OpenAI Api key
openai_api_key = "your-openai_api_key"

# These values appear after first terraform apply (cognito module)
# cognito_user_pool_id  = "XXXXXXXXXXXXXXXXX"
# cognito_app_client_id = "XXXXXXXXXXXXXXXXXXXXXXXXXX"